{
    "name": "dvsa/mot-feature-toggle",
    "description": "Shared facility to toggle functionality within the codebase",
    "require": {
        "php": "^8.2",
        "laminas/laminas-dependency-plugin": "^2.7.0",
        "laminas/laminas-servicemanager": "^3.24.0",
        "laminas/laminas-view": "^2.44.0"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.28.4",
        "captainhook/plugin-composer": "^5.3.3",
        "friendsofphp/php-cs-fixer": "^v3.92.4",
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.13.5",
        "vimeo/psalm": "^6.14.3",
        "dvsa/coding-standards": "^2.0",
        "phpstan/phpstan": "^2.1.33"
    },
    "autoload": {
        "psr-4": {
            "DvsaFeature\\": "src/",
            "DvsaFeatureTest\\": "test/"
        },
        "classmap": [
            "./Module.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "./vendor/bin/phpcs .",
        "phpcs-fix": "./vendor/bin/phpcbf .",
        "psalm": "./vendor/bin/psalm" ,
        "phpstan": "vendor/bin/phpstan analyse"

    },
    "config": {
        "allow-plugins": {
            "laminas/laminas-dependency-plugin": true,
            "captainhook/plugin-composer": true
        }
    }
}
